# OpenWeatherMap API key (free tier: https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_api_key_here

# Default location for weather
WEATHER_LAT=39.0997
WEATHER_LON=-94.5786

# Airport ICAO code for aviation weather (e.g., KJFK, KORD, KMCI)
METAR_AIRPORT=KMCI

# Timezone (used for display)
TZ=America/Chicago
